---
import Layout from '../layouts/Layout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import About from '../components/About.astro';
import SocialPill from '../components/SocialPill.astro';
import GitHubIcon from '../icons/GitHub.astro';
import LinkedInIcon from '../icons/LinkedIn.astro';
import MailIcon from '../icons/Mail.astro';
import PdfIcon from '../icons/Pdf.astro';
---

<Layout
  title="Portfolio — Mauricio Jourdán · Full Stack Developer"
  description="Desarrollador web Full Stack con más de 14 años de experiencia en desarrollo de sistemas."
>
  <main>

    <!-- HERO -->
    <section class="hero" id="top">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-inner">

        <p class="hero-label">
          <span class="hero-cursor" aria-hidden="true">›_</span>
          Hola, soy
        </p>

        <h1 class="hero-name" aria-label="Mauricio Jourdán">
          <span class="name-line name-first">MAURICIO</span>
          <span class="name-line name-last">JOURDÁN</span>
        </h1>

        <p class="hero-sub">
          Desarrollador Full Stack
          <span class="hero-dot" aria-hidden="true">·</span>
          +14 años en sistemas
          <span class="hero-dot" aria-hidden="true">·</span>
          Argentina
        </p>

        <nav class="hero-links" aria-label="Redes y contacto">
          <SocialPill href="https://www.linkedin.com/in/mauricio-adrian-jourdan-2104b219/">
            <LinkedInIcon class="size-4" />
            LinkedIn
          </SocialPill>
          <SocialPill href="https://github.com/jourdanmauricio/">
            <GitHubIcon class="size-4" />
            GitHub
          </SocialPill>
          <SocialPill href="/Mauricio-Jourdan.pdf">
            <PdfIcon class="size-4" />
            Descargar CV
          </SocialPill>
          <SocialPill href="mailto:jourdanmauricio@gmail.com">
            <MailIcon class="size-4" />
            Email
          </SocialPill>
        </nav>
      </div>

      <div class="hero-scroll-hint" aria-hidden="true">
        <span class="scroll-line"></span>
        <span class="scroll-label">scroll</span>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <SectionContainer id="experience" class="section-block reveal">
      <header class="section-header">
        <span class="section-num" aria-hidden="true">01</span>
        <h2 class="section-title">Experiencia laboral</h2>
      </header>
      <Experience />
    </SectionContainer>

    <!-- PROJECTS -->
    <SectionContainer id="projects" class="section-block reveal">
      <header class="section-header">
        <span class="section-num" aria-hidden="true">02</span>
        <h2 class="section-title">Proyectos</h2>
      </header>
      <Projects />
    </SectionContainer>

    <!-- ABOUT -->
    <SectionContainer id="about" class="section-block reveal">
      <header class="section-header">
        <span class="section-num" aria-hidden="true">03</span>
        <h2 class="section-title">Sobre mí</h2>
      </header>
      <About />
    </SectionContainer>

  </main>
</Layout>

<style>
  main {
    padding-top: 60px;
    position: relative;
    z-index: 1;
  }

  /* ── HERO ─────────────────────────────────── */
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 1.5rem 4rem;
    max-width: 960px;
    margin: 0 auto;
    position: relative;
  }

  .hero-glow {
    position: absolute;
    top: 10%;
    left: -15%;
    width: 55%;
    height: 55%;
    background: radial-gradient(ellipse, rgba(184, 255, 58, 0.05) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* Label */
  .hero-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    animation: fade-up 0.7s ease both;
  }

  .hero-cursor {
    color: var(--accent);
    font-family: 'Courier New', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    animation: blink 1.1s step-end infinite;
    line-height: 1;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Name */
  .hero-name {
    display: flex;
    flex-direction: column;
    line-height: 0.88;
    animation: fade-up 0.7s ease 0.15s both;
  }

  .name-line {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(3.5rem, 11.5vw, 8.5rem);
    letter-spacing: -0.025em;
    display: block;
  }

  .name-first {
    color: var(--text);
  }

  .name-last {
    color: var(--accent);
    margin-left: clamp(0.5rem, 3.5vw, 3.5rem);
  }

  /* Subtitle */
  .hero-sub {
    font-size: clamp(0.8rem, 1.8vw, 1rem);
    color: var(--text-muted);
    letter-spacing: 0.05em;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    animation: fade-up 0.7s ease 0.28s both;
  }

  .hero-dot {
    color: var(--accent);
    opacity: 0.6;
  }

  /* Links */
  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    animation: fade-up 0.7s ease 0.42s both;
  }

  /* Scroll hint */
  .hero-scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    animation: fade-up 0.7s ease 0.7s both;
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: grow-line 1.4s ease 1s both;
  }

  @keyframes grow-line {
    from { transform: scaleY(0); transform-origin: top; }
    to { transform: scaleY(1); transform-origin: top; }
  }

  .scroll-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-dim);
    writing-mode: vertical-rl;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3rem 1.25rem 3rem;
      justify-content: flex-start;
      padding-top: 4rem;
    }
    .hero-scroll-hint {
      display: none;
    }
    .hero-inner {
      gap: 1.25rem;
    }
  }

  /* ── SECTIONS ─────────────────────────────── */
  .section-block {
    padding-top: 6rem;
    padding-bottom: 3rem;
  }

  @media (max-width: 640px) {
    .section-block {
      padding-top: 4rem;
      padding-bottom: 2rem;
    }
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .section-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.3rem, 3.5vw, 1.75rem);
    color: var(--text);
    letter-spacing: -0.015em;
  }
</style>
