<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.85;
    max-width: 62ch;
  }

  .edu-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .edu-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .edu-item {
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
    align-items: start;
  }

  .edu-year {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.7rem;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    padding-top: 3px;
  }

  .edu-school {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text);
    margin-bottom: 0.15rem;
  }

  .edu-degree {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
  }

  .edu-period {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  .edu-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.82rem;
    transition: opacity 0.2s;
  }

  .edu-link:hover {
    opacity: 0.75;
  }
</style>
