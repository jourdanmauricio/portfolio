---
interface Props {
  title: string;
  description: string[];
  link?: string;
  date: string;
  company: string;
}

const { title, description, date, company } = Astro.props;
---

<div class="exp-card">
  <div class="exp-meta">
    <time class="exp-date">{date}</time>
    <span class="exp-company">{company}</span>
  </div>
  <div class="exp-content">
    <h3 class="exp-title">{title}</h3>
    <details>
      <summary>Ver descripción</summary>
      <ul>
        {description.map((desc) => <li>{desc}</li>)}
      </ul>
    </details>
  </div>
</div>

<style>
  .exp-card {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  @media (max-width: 640px) {
    .exp-card {
      grid-template-columns: 1fr;
      gap: 0.4rem;
      padding: 1.25rem 0;
    }
    .exp-meta {
      flex-direction: row;
      align-items: center;
      gap: 0.75rem;
    }
  }

  .exp-meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 2px;
  }

  .exp-date {
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
  }

  .exp-company {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .exp-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
</style>
